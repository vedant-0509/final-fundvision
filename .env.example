# ── FundVision Pro — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values. NEVER commit .env to git.

# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME="FundVision Pro"
APP_VERSION="2.0.0"
DEBUG=false
# Comma-separated list — no spaces, no brackets
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# ── Security ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_64_char_random_string_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ───────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fundvision
DB_USER=root
DB_PASSWORD=root

# ── AI (Anthropic) ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=asadsad
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Financial Data APIs ────────────────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=
AMFI_NAV_URL=https://www.amfiindia.com/spages/NAVAll.txt
NEWS_API_KEY=